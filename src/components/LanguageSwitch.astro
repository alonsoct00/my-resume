---
---
<div class="lang-switch no-print" id="lang-switch">
  <button data-lang-btn="es" title="Español">ES</button>
  <span>|</span>
  <button data-lang-btn="en" title="English">EN</button>
</div>

<script>
  function getPreferredLang(): "es" | "en" {
    const saved = localStorage.getItem("cv-lang") as "es" | "en" | null;
    if (saved) return saved;
    const browser = navigator.language.toLowerCase();
    return browser.startsWith("es") ? "es" : "en";
  }

  function applyLang(lang: "es" | "en") {
    document.documentElement.setAttribute("data-lang", lang);
    localStorage.setItem("cv-lang", lang);
    document.querySelectorAll("[data-lang-btn]").forEach((btn) => {
      const b = btn as HTMLButtonElement;
      b.classList.toggle("active", b.dataset.langBtn === lang);
    });
  }

  // Aplicar idioma al cargar
  const lang = getPreferredLang();
  applyLang(lang);

  // Listeners del switch
  document.querySelectorAll("[data-lang-btn]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const selected = (btn as HTMLButtonElement).dataset.langBtn as "es" | "en";
      applyLang(selected);
    });
  });
</script>

<style>
  .lang-switch {
    position: fixed;
    top: 1rem;
    right: 1rem;
    display: flex;
    align-items: center;
    gap: 4px;
    background: rgba(255,255,255,0.9);
    border: 1px solid #ddd;
    border-radius: 20px;
    padding: 4px 10px;
    font-size: 0.75rem;
    font-weight: 600;
    z-index: 100;
    backdrop-filter: blur(4px);
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }

  button {
    background: none;
    border: none;
    cursor: pointer;
    padding: 2px 4px;
    border-radius: 4px;
    color: #999;
    font-size: 0.75rem;
    font-weight: 600;
    font-family: inherit;
    transition: color 0.2s;
  }

  button.active {
    color: #111;
  }

  span {
    color: #ccc;
  }
</style>