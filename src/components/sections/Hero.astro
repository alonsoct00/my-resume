---
import { basics as basics_es } from "@cv"
import { basics as basics_en } from "@cv_en"
import Section from "@/components/Section.astro"

// Tipo para los iconos: componente Astro
type AstroIcon = (props?: any) => any

// Cargamos todos los iconos dinámicamente
const SOCIAL_ICONS: Record<string, AstroIcon> = {}
const iconModules = import.meta.glob<{ default: AstroIcon }>('@/icons/*.astro')

for (const [path, loader] of Object.entries(iconModules)) {
  const name = path.split('/').pop()!.replace('.astro','').toLowerCase()
  SOCIAL_ICONS[name] = (await loader()).default
}

const { name, image, profiles, phone, email } = basics_es
const linkedInfo = profiles.find(({ network }) => network.toLowerCase() === "linkedin")
const linkedUrl = linkedInfo?.url
const printInfo = [email, phone, linkedUrl].filter(Boolean).join(" • ")

// Extraemos los iconos específicos para evitar errores de JSX
const MailIcon = SOCIAL_ICONS["mail"]
const PhoneIcon = SOCIAL_ICONS["phone"]
const WorldMapIcon = SOCIAL_ICONS["worldmap"]
---
<Section id="hero">
  <div class="container">
    <div class="info">
      <h1>{name}</h1>

      <h2 data-lang-content="es">{basics_es.label}</h2>
      <h2 data-lang-content="en">{basics_en.label}</h2>

      <span>
        {WorldMapIcon && <WorldMapIcon />}
        <span data-lang-content="es">{basics_es.location.city}, {basics_es.location.region}</span>
        <span data-lang-content="en">{basics_en.location.city}, {basics_en.location.region}</span>
      </span>

      <footer class="print">{printInfo}</footer>
      <footer class="no-print">
        {email && MailIcon && (
          <a href={`mailto:${email}`} title={`Email ${name}`} target="_blank" rel="noopener noreferrer">
            <MailIcon />
          </a>
        )}
        {phone && PhoneIcon && (
          <a href={`tel:${phone}`} title={`Call ${name}`} target="_blank" rel="noopener noreferrer">
            <PhoneIcon />
          </a>
        )}
        {profiles.map(({ network, url }) => {
          const Component = SOCIAL_ICONS[network.toLowerCase()]
          return Component ? (
            <a href={url} title={`${name} on ${network}`} target="_blank" rel="noopener noreferrer">
              <Component />
            </a>
          ) : null
        })}
      </footer>
    </div>
    <figure>
      <img src={image} alt={name} />
    </figure>
  </div>
</Section>