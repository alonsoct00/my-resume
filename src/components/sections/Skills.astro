---
import Section from "../Section.astro"
import { skills as skills_es, languages as languages_es } from "@cv"
import { skills as skills_en, languages as languages_en } from "@cv_en"

const languaged = "es";
const skills = languaged === "es" ? skills_es : skills_en;
const languages = languaged === "es" ? languages_es : languages_en;

const astroIcons = import.meta.glob<{ default: any }>('@/icons/*.astro')
const svgIcons = import.meta.glob<string>('/public/icons/*.svg', { query: '?url', import: 'default' })

function slugify(name: string) {
  return name.toLowerCase().replace(/[\s.]/g, "").replace(/-/g, "")
}

async function getIcon(name: string) {
  const slug = slugify(name)
  
  const astroMatch = Object.entries(astroIcons).find(([path]) =>
    path.toLowerCase().includes(`/${slug}.astro`)
  )
  if (astroMatch) {
    const mod = await astroMatch[1]()
    return { type: 'astro' as const, Component: mod.default }
  }

  const svgMatch = Object.entries(svgIcons).find(([path]) =>
    path.toLowerCase().includes(`/${slug}.svg`)
  )
  if (svgMatch) return { type: 'svg' as const, url: await svgMatch[1]() }

  return null
}

const resolvedSkills = await Promise.all(
  skills.map(async ({ name, keywords }) => ({
    name,
    keywords,
    icon: await getIcon(name)
  }))
)
---

<Section title="Habilidades y conocimientos">
  <ul>
    {resolvedSkills.map(({ name, keywords, icon }) => {
      const Icon = icon?.type === 'astro' ? icon.Component : null
      return (
        <li title={keywords.join(", ")}>
          {Icon && <Icon />}
          {icon?.type === 'svg' && <img src={icon.url} alt={name} width="14" height="14" />}
          <span>{name}</span>
        </li>
      )
    })}
  </ul>
</Section>

<Section title="Idiomas">
  <ul>
    {languages.map(({ language, fluency }) => (
      <li>
        <p>{language}</p>
        <span>{fluency}</span>
      </li>
    ))}
  </ul>
</Section>

<style>
  ul {
    display: inline-flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  li {
    align-items: center;
    background: #eee;
    border-radius: 6px;
    color: black;
    display: flex;
    font-size: 0.8rem;
    font-weight: 500;
    gap: 4px;
    padding: 0.2rem 0.6rem;
  }
</style>