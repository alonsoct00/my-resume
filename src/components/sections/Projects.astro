---
// Projects.astro
import Section from "../Section.astro"
import ICONS from "@/lib/icons"
import { projects as projects_es } from "@cv"
import { projects as projects_en } from "@cv_en"

const GitHubIcon = ICONS["github"]
const WebflowIcon = ICONS["webflow"]
---

<Section id="projects">
  <h2 data-lang-content="es">Proyectos y portafolio</h2>
  <h2 data-lang-content="en">Projects & Portfolio</h2>

  <ul class="projects-grid" data-lang-content="es">
    {projects_es.map(({ url, description, highlights, name, isActive, github, webflow }) => {
      return (
        <li>
          <article>
            <header>
              <h3>
                <a href={url} target="_blank" title={`Ver el proyecto ${name}`}>{name}</a>
                {isActive && <span>•</span>}
                {github && GitHubIcon && <a class="github-code-link" href={github} target="_blank" title={`Código fuente ${name}`}><GitHubIcon /></a>}
                {webflow && WebflowIcon && <a class="webflow-code-link" href={webflow} target="_blank" title={`Webflow ${name}`}><WebflowIcon /></a>}
              </h3>
              <p>{description}</p>
            </header>
            <footer>
              {highlights.map((h) => <span>{h}</span>)}
            </footer>
          </article>
        </li>
      )
    })}
  </ul>

  <ul class="projects-grid" data-lang-content="en">
    {projects_en.map(({ url, description, highlights, name, isActive, github, webflow }) => {
      return (
        <li>
          <article>
            <header>
              <h3>
                <a href={url} target="_blank" title={`View project ${name}`}>{name}</a>
                {isActive && <span>•</span>}
                {github && GitHubIcon && <a class="github-code-link" href={github} target="_blank" title={`Source code ${name}`}><GitHubIcon /></a>}
                {webflow && WebflowIcon && <a class="webflow-code-link" href={webflow} target="_blank" title={`Webflow ${name}`}><WebflowIcon /></a>}
              </h3>
              <p>{description}</p>
            </header>
            <footer>
              {highlights.map((h) => <span>{h}</span>)}
            </footer>
          </article>
        </li>
      )
    })}
  </ul>
</Section>

<style>
  #projects .projects-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 1rem;
  margin-inline: -16px;
}
</style>