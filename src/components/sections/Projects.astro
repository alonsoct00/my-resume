---
// Projects.astro
import Section from "../Section.astro"
import ICONS from "@/lib/icons"
import { projects as projects_es } from "@cv"
import { projects as projects_en } from "@cv_en"

const language = "es"
const projects = language === "es" ? projects_es : projects_en
---

<Section title="Proyectos y portafolio" id="projects">
  <ul>
    {projects.map(({ url, description, highlights, name, isActive, github, webflow }) => {
      const GitHubIcon = ICONS["github"]
      const WebflowIcon = ICONS["webflow"]

      return (
        <li>
          <article>
            <header>
              <h3>
                <a href={url} target="_blank" title={`Ver el proyecto ${name}`}>{name}</a>
                {isActive && <span>•</span>}
                {github && GitHubIcon && <a class="github-code-link" href={github} target="_blank" title={`Código fuente ${name}`}><GitHubIcon /></a>}
                {webflow && WebflowIcon && <a class="webflow-code-link" href={webflow} target="_blank" title={`Webflow ${name}`}><WebflowIcon /></a>}
              </h3>
              <p>{description}</p>
            </header>
            <footer>
              {highlights.map((h) => <span>{h}</span>)}
            </footer>
          </article>
        </li>
      )
    })}
  </ul>
</Section>